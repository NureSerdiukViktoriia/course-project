VALUES
('listening', 'Apple', '[&quot;яблуко&quot;,&quot;собака&quot;,&quot;книга&quot;,&quot;вода&quot;]', 'яблуко', 'початковий'),
('listening', 'Dog', '[&quot;кіт&quot;,&quot;собака&quot;,&quot;птах&quot;,&quot;риба&quot;]', 'собака', 'початковий'),
('listening', 'Book', '[&quot;стіл&quot;,&quot;книга&quot;,&quot;ручка&quot;,&quot;стілець&quot;]', 'книга', 'початковий'),
('listening', 'Water', '[&quot;вода&quot;,&quot;вогонь&quot;,&quot;земля&quot;,&quot;повітря&quot;]', 'вода', 'початковий'),
('listening', 'Sun', '[&quot;місяць&quot;,&quot;сонце&quot;,&quot;зірка&quot;,&quot;небо&quot;]', 'сонце', 'початковий'),
('listening', 'House', '[&quot;будинок&quot;,&quot;машина&quot;,&quot;школа&quot;,&quot;сад&quot;]', 'будинок', 'початковий'),
('listening', 'Cat', '[&quot;кіт&quot;,&quot;пес&quot;,&quot;кінь&quot;,&quot;миша&quot;]', 'кіт', 'початковий'),
('listening', 'School', '[&quot;лікарня&quot;,&quot;школа&quot;,&quot;магазин&quot;,&quot;парк&quot;]', 'школа', 'початковий'),
('listening', 'Milk', '[&quot;молоко&quot;,&quot;чай&quot;,&quot;кава&quot;,&quot;сік&quot;]', 'молоко', 'початковий'),
('listening', 'Table', '[&quot;стіл&quot;,&quot;стілець&quot;,&quot;вікно&quot;,&quot;двері&quot;]', 'стіл', 'початковий'),

('listening', 'Journey', '[&quot;подорож&quot;,&quot;робота&quot;,&quot;помилка&quot;,&quot;відповідь&quot;]', 'подорож', 'середній'),
('listening', 'Weather', '[&quot;погода&quot;,&quot;вікно&quot;,&quot;свято&quot;,&quot;зустріч&quot;]', 'погода', 'середній'),
('listening', 'Appointment', '[&quot;зустріч&quot;,&quot;магазин&quot;,&quot;квиток&quot;,&quot;дорога&quot;]', 'зустріч', 'середній'),
('listening', 'Library', '[&quot;бібліотека&quot;,&quot;лікарня&quot;,&quot;аеропорт&quot;,&quot;ресторан&quot;]', 'бібліотека', 'середній'),
('listening', 'Advice', '[&quot;порада&quot;,&quot;помилка&quot;,&quot;правило&quot;,&quot;питання&quot;]', 'порада', 'середній'),
('listening', 'Neighbour', '[&quot;сусід&quot;,&quot;вчитель&quot;,&quot;лікар&quot;,&quot;водій&quot;]', 'сусід', 'середній'),
('listening', 'Ticket', '[&quot;квиток&quot;,&quot;лист&quot;,&quot;ручка&quot;,&quot;ключ&quot;]', 'квиток', 'середній'),
('listening', 'Healthy', '[&quot;здоровий&quot;,&quot;швидкий&quot;,&quot;дорогий&quot;,&quot;важкий&quot;]', 'здоровий', 'середній'),
('listening', 'Important', '[&quot;важливий&quot;,&quot;простий&quot;,&quot;тихий&quot;,&quot;старий&quot;]', 'важливий', 'середній'),
('listening', 'Question', '[&quot;питання&quot;,&quot;відповідь&quot;,&quot;приклад&quot;,&quot;текст&quot;]', 'питання', 'середній'),

('listening', 'Achievement', '[&quot;досягнення&quot;,&quot;помилка&quot;,&quot;переклад&quot;,&quot;звичка&quot;]', 'досягнення', 'просунутий'),
('listening', 'Responsibility', '[&quot;відповідальність&quot;,&quot;можливість&quot;,&quot;небезпека&quot;,&quot;перевага&quot;]', 'відповідальність', 'просунутий'),
('listening', 'Environment', '[&quot;довкілля&quot;,&quot;суспільство&quot;,&quot;освіта&quot;,&quot;економіка&quot;]', 'довкілля', 'просунутий'),
('listening', 'Opportunity', '[&quot;можливість&quot;,&quot;складність&quot;,&quot;відповідь&quot;,&quot;перешкода&quot;]', 'можливість', 'просунутий'),
('listening', 'Development', '[&quot;розвиток&quot;,&quot;зменшення&quot;,&quot;порівняння&quot;,&quot;заборона&quot;]', 'розвиток', 'просунутий'),
('listening', 'Experience', '[&quot;досвід&quot;,&quot;вправа&quot;,&quot;правило&quot;,&quot;порада&quot;]', 'досвід', 'просунутий'),
('listening', 'Explanation', '[&quot;пояснення&quot;,&quot;запитання&quot;,&quot;рішення&quot;,&quot;помилка&quot;]', 'пояснення', 'просунутий'),
('listening', 'Improvement', '[&quot;покращення&quot;,&quot;повторення&quot;,&quot;виконання&quot;,&quot;обмеження&quot;]', 'покращення', 'просунутий'),
('listening', 'Conversation', '[&quot;розмова&quot;,&quot;відповідь&quot;,&quot;речення&quot;,&quot;слово&quot;]', 'розмова', 'просунутий'),
('listening', 'Knowledge', '[&quot;знання&quot;,&quot;навичка&quot;,&quot;успіх&quot;,&quot;оцінка&quot;]', 'знання', 'просунутий');</sql><current_tab id="0"/></tab_sql></sqlb_project>
